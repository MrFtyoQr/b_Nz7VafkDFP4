# ============================================================
# CUPONERA CAMSA — Variables de entorno (Frontend Next.js)
# Copia este archivo a .env.local y rellena los valores
# ============================================================

# --- Supabase (Públicas) ---
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_<tu-anon-key>

# --- Supabase (Privada — Solo servidor) ---
# Supabase Dashboard → Project Settings → API → Secret key
SUPABASE_SERVICE_ROLE_KEY=<tu-service-role-key>

# --- Backend API (Express en Docker) ---
BACKEND_API_URL=http://localhost:3001

# --- Entorno ---
NODE_ENV=development
