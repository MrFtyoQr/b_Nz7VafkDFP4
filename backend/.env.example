# ============================================================
# CUPONERA CAMSA — Backend Express
# Copia a .env y rellena los valores reales
# ============================================================

# Puerto del servidor
PORT=3001

# Supabase — URL del proyecto
SUPABASE_URL=https://<project-ref>.supabase.co

# Supabase — Secret key (service_role)
# Supabase Dashboard → Project Settings → API → Secret key
SUPABASE_SERVICE_ROLE_KEY=<tu-service-role-key>

# Supabase — Anon/Publishable key (para verificar JWTs de usuarios)
SUPABASE_ANON_KEY=sb_publishable_<tu-anon-key>

# CORS — Orígenes permitidos (separados por coma)
ALLOWED_ORIGINS=http://localhost:3000,https://cuponera.camsa.com.mx

# Entorno
NODE_ENV=development
